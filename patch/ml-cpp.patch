index 0000000..8103d8f
--- /dev/null
+++ b/s390x/build_ml_cpp.sh
@@ -0,0 +1,732 @@
+#!/usr/bin/env bash
+# ml-cpp build helpers sourced by build_elasticsearch.sh.
+
+ML_CPP_REPO_URL="${ML_CPP_REPO_URL:-https://github.com/elastic/ml-cpp}"
+ML_CPP_REF="${ML_CPP_REF:-v${PACKAGE_VERSION}}"
+ML_CPP_REPO="${ML_CPP_REPO:-/tmp/mlcpp-ivy}"
+ML_CPP_GRADLE_OPTS=""
+ML_CPP_GRADLE_TASKS="${ML_CPP_GRADLE_TASKS:-buildZip buildDependenciesZip buildNoDependenciesZip}"
+ML_CPP_FORCE_REBUILD="${ML_CPP_FORCE_REBUILD:-false}"
+ML_CPP_SOURCE_DIR="${ML_CPP_SOURCE_DIR:-$SOURCE_ROOT/ml-cpp}"
+ML_CPP_JAVA_HOME="${ML_CPP_JAVA_HOME:-/opt/java/jdk17}"
+ML_CPP_BOOST_ROOT="${ML_CPP_BOOST_ROOT:-/usr/local/gcc133}"
+ML_CPP_BOOST_SOURCE_DIR="${ML_CPP_BOOST_SOURCE_DIR:-$SOURCE_ROOT/boost_1_86_0}"
+ML_PYTORCH_ROOT="${ML_PYTORCH_ROOT:-}"
+ML_PYTORCH_HOME="${ML_PYTORCH_HOME:-}"
+ML_PYTORCH_LIB_DIR="${ML_PYTORCH_LIB_DIR:-}"
+ML_PYTORCH_REPO_URL="${ML_PYTORCH_REPO_URL:-https://github.com/pytorch/pytorch}"
+ML_PYTORCH_REF="${ML_PYTORCH_REF:-v2.7.1}"
+ML_PYTORCH_SOURCE_DIR="${ML_PYTORCH_SOURCE_DIR:-$SOURCE_ROOT/pytorch}"
+ML_PYTORCH_BUILD_FROM_SOURCE="${ML_PYTORCH_BUILD_FROM_SOURCE:-true}"
+ML_PYTORCH_BUILD_PARALLEL_LEVEL="${ML_PYTORCH_BUILD_PARALLEL_LEVEL:-${ML_CPP_BUILD_PARALLEL_LEVEL:-4}}"
+ML_PYTORCH_SUBMODULE_JOBS="${ML_PYTORCH_SUBMODULE_JOBS:-1}"
+PYTHON_BIN="${PYTHON_BIN:-python3}"
+EXPAT_RUNTIME_VERSION="${EXPAT_RUNTIME_VERSION:-2.8.1}"
+EXPAT_RUNTIME_URL="${EXPAT_RUNTIME_URL:-https://github.com/libexpat/libexpat/releases/download/R_2_8_1/expat-2.8.1.tar.bz2}"
+EXPAT_RUNTIME_PREFIX="${EXPAT_RUNTIME_PREFIX:-$SOURCE_ROOT/expat-${EXPAT_RUNTIME_VERSION}-runtime}"
+PYTHON_RUNTIME_LIBRARY_PATH="${PYTHON_RUNTIME_LIBRARY_PATH:-}"
+
+function mlCppRepoPath() {
+    if [[ "$ML_CPP_REPO" == file://* ]]; then
+        printf -- '%s' "${ML_CPP_REPO#file://}"
+    elif [[ "$ML_CPP_REPO" == http://* || "$ML_CPP_REPO" == https://* ]]; then
+        printf -- ''
+    else
+        printf -- '%s' "$ML_CPP_REPO"
+    fi
+}
+
+function mlCppRepoUrl() {
+    if [[ "$ML_CPP_REPO" == file://* || "$ML_CPP_REPO" == http://* || "$ML_CPP_REPO" == https://* ]]; then
+        printf -- '%s' "$ML_CPP_REPO"
+    else
+        printf -- 'file://%s' "$ML_CPP_REPO"
+    fi
+}
+
+function mlCppArtifactDir() {
+    local ml_cpp_repo_path="$1"
+    printf -- '%s/maven/org/elasticsearch/ml/ml-cpp/%s-SNAPSHOT' "$ml_cpp_repo_path" "$PACKAGE_VERSION"
+}
+
+function ensureMlCppDepsZip() {
+    local deps_zip="$1"
+
+    if [[ -f "$deps_zip" ]]; then
+        return 0
+    fi
+
+    printf -- 'ml-cpp deps zip was not found; creating an empty deps artifact at %s.\n' "$deps_zip" |& tee -a "$LOG_FILE"
+    mkdir -p "$(dirname "$deps_zip")"
+    python3 -c 'import sys, zipfile; zipfile.ZipFile(sys.argv[1], "w").close()' "$deps_zip"
+}
+
+function runBuildPython() {
+    if [[ -n "$PYTHON_RUNTIME_LIBRARY_PATH" ]]; then
+        env LD_LIBRARY_PATH="$PYTHON_RUNTIME_LIBRARY_PATH" "$PYTHON_BIN" "$@"
+    else
+        env -u LD_LIBRARY_PATH "$PYTHON_BIN" "$@"
+    fi
+}
+
+function expatRuntimeHasPythonSymbol() {
+    local expat_lib="$1"
+
+    [[ -e "$expat_lib" ]] || return 1
+    if command -v nm >/dev/null 2>&1 && nm -D "$expat_lib" 2>/dev/null | awk '{print $NF}' | grep -qx 'XML_SetAllocTrackerActivationThreshold'; then
+        return 0
+    fi
+    if command -v readelf >/dev/null 2>&1 && readelf -Ws "$expat_lib" 2>/dev/null | awk '{print $NF}' | grep -qx 'XML_SetAllocTrackerActivationThreshold'; then
+        return 0
+    fi
+    strings "$expat_lib" 2>/dev/null | grep -q 'XML_SetAllocTrackerActivationThreshold'
+}
+
+function useExistingPythonExpatRuntime() {
+    [[ -e "$EXPAT_RUNTIME_PREFIX/lib/libexpat.so.1" ]] || return 1
+    PYTHON_RUNTIME_LIBRARY_PATH="$EXPAT_RUNTIME_PREFIX/lib"
+    export PYTHON_RUNTIME_LIBRARY_PATH
+}
+
+function configurePythonExpatRuntime() {
+    local expat_source_dir="$SOURCE_ROOT/expat-${EXPAT_RUNTIME_VERSION}"
+    local expat_archive="$SOURCE_ROOT/expat-${EXPAT_RUNTIME_VERSION}.tar.bz2"
+
+    if useExistingPythonExpatRuntime && runBuildPython -c 'import xml.parsers.expat' >/dev/null 2>&1; then
+        return
+    fi
+    PYTHON_RUNTIME_LIBRARY_PATH=""
+
+    printf -- 'Building Expat %s runtime for %s because its system pyexpat runtime is incompatible.\n' "$EXPAT_RUNTIME_VERSION" "$PYTHON_BIN" |& tee -a "$LOG_FILE"
+    rm -rf "$expat_source_dir" "$EXPAT_RUNTIME_PREFIX"
+    curl -SL -o "$expat_archive" "$EXPAT_RUNTIME_URL"
+    tar -xjf "$expat_archive" -C "$SOURCE_ROOT"
+
+    cd "$expat_source_dir"
+    ./configure --prefix="$EXPAT_RUNTIME_PREFIX" --without-docbook --without-examples |& tee -a "$LOG_FILE"
+    make -j "${ML_CPP_BUILD_PARALLEL_LEVEL:-4}" |& tee -a "$LOG_FILE"
+    make install |& tee -a "$LOG_FILE"
+
+    PYTHON_RUNTIME_LIBRARY_PATH="$EXPAT_RUNTIME_PREFIX/lib"
+    export PYTHON_RUNTIME_LIBRARY_PATH
+    if ! expatRuntimeHasPythonSymbol "$EXPAT_RUNTIME_PREFIX/lib/libexpat.so.1"; then
+        printf -- 'Built Expat runtime did not expose XML_SetAllocTrackerActivationThreshold via symbol inspection; validating with Python import instead.\n' |& tee -a "$LOG_FILE"
+    fi
+}
+
+function ensureBuildPythonUsable() {
+    local python_check_output
+
+    if python_check_output="$(runBuildPython -c 'import sys; print(sys.version); import xml.parsers.expat; print("pyexpat ok")' 2>&1)"; then
+        printf -- 'Using build Python %s: %s\n' "$PYTHON_BIN" "$(printf -- '%s\n' "$python_check_output" | head -1)" |& tee -a "$LOG_FILE"
+        return
+    fi
+
+    printf -- 'Build Python %s failed pyexpat import:\n%s\n' "$PYTHON_BIN" "$python_check_output" |& tee -a "$LOG_FILE"
+    if useExistingPythonExpatRuntime && python_check_output="$(runBuildPython -c 'import sys; print(sys.version); import xml.parsers.expat; print("pyexpat ok")' 2>&1)"; then
+        printf -- 'Using build Python %s with existing Expat runtime %s: %s\n' "$PYTHON_BIN" "$EXPAT_RUNTIME_PREFIX" "$(printf -- '%s\n' "$python_check_output" | head -1)" |& tee -a "$LOG_FILE"
+        return
+    fi
+    PYTHON_RUNTIME_LIBRARY_PATH=""
+    configurePythonExpatRuntime
+
+    if ! python_check_output="$(runBuildPython -c 'import sys; print(sys.version); import xml.parsers.expat; print("pyexpat ok")' 2>&1)"; then
+        printf -- 'Build Python %s is still unusable after configuring Expat runtime:\n%s\n' "$PYTHON_BIN" "$python_check_output" |& tee -a "$LOG_FILE"
+        exit 1
+    fi
+
+    printf -- 'Using build Python %s with Expat runtime %s: %s\n' "$PYTHON_BIN" "$EXPAT_RUNTIME_PREFIX" "$(printf -- '%s\n' "$python_check_output" | head -1)" |& tee -a "$LOG_FILE"
+}
+
+function findSystemLibrary() {
+    local library="$1" candidate candidates=("/usr/lib64/$library" "/usr/lib/$library" "/usr/lib/$(uname -m)-linux-gnu/$library")
+    if command -v gcc >/dev/null 2>&1; then
+        candidate="$(gcc -print-file-name="$library" 2>/dev/null || true)"
+        [[ -n "$candidate" && "$candidate" != "$library" ]] && candidates+=("$candidate")
+    fi
+    if command -v ldconfig >/dev/null 2>&1; then
+        candidate="$(ldconfig -p 2>/dev/null | awk -v library="$library" '$1 == library { print $NF; exit }')"
+        [[ -n "$candidate" ]] && candidates+=("$candidate")
+    fi
+    for candidate in "${candidates[@]}"; do [[ -e "$candidate" ]] && readlink -f "$candidate" && return 0; done
+    return 1
+}
+
+function findMlCppBoostLibDir() {
+    local candidate_dir
+
+    for candidate_dir in "$ML_CPP_BOOST_ROOT/lib" "$ML_CPP_BOOST_SOURCE_DIR/stage/lib"; do
+        if [[ -d "$candidate_dir" ]] && find "$candidate_dir" -maxdepth 1 -type f -name 'libboost_program_options*.so.*' -print -quit | grep -q .; then
+            printf -- '%s' "$candidate_dir"
+            return 0
+        fi
+    done
+
+    return 1
+}
+
+function mlCppBoostCompilerTag() {
+    local boost_lib boost_name
+
+    boost_lib="$(find "$ML_CPP_BOOST_ROOT/lib" -maxdepth 1 -type f -name 'libboost_iostreams-gcc*-1_86.*' 2>/dev/null | head -1 || true)"
+    [[ -n "$boost_lib" ]] || return 1
+    boost_name="$(basename "$boost_lib")"
+    if [[ "$boost_name" =~ -(gcc[0-9]+)- ]]; then
+        printf -- '%s' "${BASH_REMATCH[1]}"
+        return 0
+    fi
+    return 1
+}
+
+function patchMlCppS390xBoostDepsZip() {
+    local deps_zip="$1" deps_zip_abs boost_lib_dir staging_dir torch_lib_dir
+
+    ensureMlCppDepsZip "$deps_zip"
+    deps_zip_abs="$(cd "$(dirname "$deps_zip")" && pwd -P)/$(basename "$deps_zip")"
+
+    if ! boost_lib_dir="$(findMlCppBoostLibDir)"; then
+        printf -- 'Unable to find Boost runtime libraries for s390x ml-cpp packaging.\n' |& tee -a "$LOG_FILE"
+        printf -- 'Checked %s/lib and %s/stage/lib.\n' "$ML_CPP_BOOST_ROOT" "$ML_CPP_BOOST_SOURCE_DIR" |& tee -a "$LOG_FILE"
+        exit 1
+    fi
+
+    staging_dir="$(mktemp -d)"
+    mkdir -p "$staging_dir/platform/linux-s390x/lib"
+
+    printf -- 'Adding s390x Boost runtime libraries from %s to %s.\n' "$boost_lib_dir" "$deps_zip" |& tee -a "$LOG_FILE"
+    find "$boost_lib_dir" -maxdepth 1 -type f -name 'libboost*.so.*' ! -name '*unit_test_framework*' ! -name '*prg_exec_monitor*' -exec cp -av {} "$staging_dir/platform/linux-s390x/lib" \; |& tee -a "$LOG_FILE"
+
+    if ! find "$staging_dir/platform/linux-s390x/lib" -maxdepth 1 -type f -name 'libboost*.so.*' -print -quit | grep -q .; then
+        printf -- 'No Boost runtime libraries were staged for s390x ml-cpp packaging.\n' |& tee -a "$LOG_FILE"
+        rm -rf "$staging_dir"
+        exit 1
+    fi
+
+    if ! unzip -Z1 "$deps_zip_abs" 2>/dev/null | grep -qx 'platform/linux-s390x/lib/libtorch_cpu.so' || ! unzip -Z1 "$deps_zip_abs" 2>/dev/null | grep -qx 'platform/linux-s390x/lib/libc10.so'; then
+        if [[ -z "${ML_PYTORCH_LIB_DIR:-}" || ! -f "$ML_PYTORCH_LIB_DIR/libtorch_cpu.so" || ! -f "$ML_PYTORCH_LIB_DIR/libc10.so" ]]; then
+            configureMlCppPytorch
+        fi
+        torch_lib_dir="$ML_PYTORCH_LIB_DIR"
+        printf -- 'Adding s390x PyTorch runtime libraries from %s to %s.\n' "$torch_lib_dir" "$deps_zip" |& tee -a "$LOG_FILE"
+        find "$torch_lib_dir" -maxdepth 1 -type f \( -name 'libtorch*.so*' -o -name 'libc10*.so*' \) -exec cp -av {} "$staging_dir/platform/linux-s390x/lib" \; |& tee -a "$LOG_FILE"
+    fi
+
+    (
+        cd "$staging_dir"; set +e
+        find platform/linux-s390x/lib -maxdepth 1 -type f -print -exec touch -t 2401010000 {} \; | sort | zip -X -u "$deps_zip_abs" -@
+        zip_status=$?; set -e
+        [[ "$zip_status" -eq 12 ]] && printf -- 's390x runtime libraries are already present in %s.\n' "$deps_zip_abs"
+        [[ "$zip_status" -eq 0 || "$zip_status" -eq 12 ]] || exit "$zip_status"
+    ) |& tee -a "$LOG_FILE"
+
+    rm -rf "$staging_dir"
+}
+
+function hasMlCppIvyArtifacts() {
+    local ml_cpp_repo_path="$1"
+    local ml_cpp_artifact_dir
+    local ml_cpp_deps_zip
+    local ml_cpp_nodeps_zip
+
+    [[ -n "$ml_cpp_repo_path" ]] || return 1
+    ml_cpp_artifact_dir="$(mlCppArtifactDir "$ml_cpp_repo_path")"
+    ml_cpp_deps_zip="$ml_cpp_artifact_dir/ml-cpp-${PACKAGE_VERSION}-SNAPSHOT-deps.zip"
+    ml_cpp_nodeps_zip="$ml_cpp_artifact_dir/ml-cpp-${PACKAGE_VERSION}-SNAPSHOT-nodeps.zip"
+
+    if [[ -f "$ml_cpp_nodeps_zip" ]]; then
+        ensureMlCppDepsZip "$ml_cpp_deps_zip"
+        if [[ -f "$ml_cpp_deps_zip" ]]; then
+            return 0
+        fi
+    fi
+
+    return 1
+}
+
+function getMlCppJavaUrl() {
+    local jruntime=$1
+    local jdist=$2
+    case "${jruntime}" in
+    "Temurin17")
+        echo "https://api.adoptium.net/v3/binary/latest/17/ga/linux/s390x/${jdist}/hotspot/normal/eclipse"
+        ;;
+    esac
+}
