+function cleanStaleMlCppBuildDir() {
+    local build_dir="$ML_CPP_SOURCE_DIR/cmake-build-relwithdebinfo" missing_prefix_lib="$ML_CPP_BOOST_ROOT/lib/libxml2.so"
+    local cmake_cache="$build_dir/CMakeCache.txt" selected_cxx cached_cxx cached_cxx_major
+
+    [[ -d "$build_dir" ]] || return
+
+    if [[ ! -e "$missing_prefix_lib" ]] && grep -R -q -F "$missing_prefix_lib" "$build_dir" 2>/dev/null; then
+        printf -- 'Removing stale ml-cpp CMake build directory that references missing %s.\n' "$missing_prefix_lib" |& tee -a "$LOG_FILE"
+        rm -rf "$build_dir"
+        return
+    fi
+
+    if [[ -f "$cmake_cache" && -n "${CMAKE_CXX_COMPILER:-}" ]]; then
+        selected_cxx="$(command -v "$CMAKE_CXX_COMPILER" 2>/dev/null || printf -- '%s' "$CMAKE_CXX_COMPILER")"
+        cached_cxx="$(sed -n 's/^CMAKE_CXX_COMPILER:[^=]*=//p' "$cmake_cache" | tail -1)"
+        if [[ -n "$cached_cxx" && -x "$cached_cxx" ]]; then
+            cached_cxx_major="$("$cached_cxx" -dumpfullversion -dumpversion 2>/dev/null | cut -d. -f1)"
+            if [[ "$cached_cxx_major" =~ ^[0-9]+$ && "$cached_cxx_major" -lt 9 ]]; then
+                printf -- 'Removing stale ml-cpp CMake build directory configured with C++20-incompatible compiler %s.\n' "$cached_cxx" |& tee -a "$LOG_FILE"
+                rm -rf "$build_dir"
+                return
+            fi
+        fi
+        if [[ -n "$cached_cxx" && "$cached_cxx" != "$selected_cxx" && "$cached_cxx" != "$CMAKE_CXX_COMPILER" ]]; then
+            printf -- 'Removing stale ml-cpp CMake build directory configured with %s; selected compiler is %s.\n' "$cached_cxx" "$selected_cxx" |& tee -a "$LOG_FILE"
+            rm -rf "$build_dir"
+        fi
+    fi
+}
