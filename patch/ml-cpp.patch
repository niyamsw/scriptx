+function installMlCppBinutilsAliases() {
+    [[ "$(uname -m)" == "s390x" ]] || return
+
+    local objcopy_path strip_path
+    objcopy_path="$(command -v objcopy || true)"
+    strip_path="$(command -v strip || true)"
+
+    if [[ -z "$objcopy_path" || -z "$strip_path" ]]; then
+        printf -- 'binutils objcopy and strip are required for the s390x ml-cpp strip task.\n' |& tee -a "$LOG_FILE"
+        exit 1
+    fi
+
+    sudo ln -sfn "$objcopy_path" /usr/local/bin/s390x-linux-gnu-objcopy
+    sudo ln -sfn "$strip_path" /usr/local/bin/s390x-linux-gnu-strip
+}
+
+function mlCppS390xPatchLooksApplied() {
+    [[ -f "cmake/linux-s390x.cmake" ]] || return 1
+    [[ -f "cmake/architecture/s390x.cmake" ]] || return 1
+    grep -q "linux-s390x" ".buildkite/scripts/steps/create_dra.sh" || return 1
+    grep -q "linux-s390x" "build.gradle" || return 1
+    grep -q "s390x" "3rd_party/3rd_party.cmake" || return 1
+    grep -q "ML_PYTORCH_LIB_DIR" "3rd_party/3rd_party.cmake" || return 1
+    grep -q "ML_ARCH_PROCESSOR" "cmake/architecture/s390x.cmake" || return 1
+    grep -q "ENV{ML_GCC_COMPILER}" "cmake/compiler/gcc.cmake" || return 1
+    grep -q "ENV{ML_BOOST_COMPILER_VER}" "cmake/variables.cmake" || return 1
+}
+
+function verifyMlCppRepo() {
+    local ml_cpp_repo_path ml_cpp_artifact_dir missing_artifacts=()
+
+    ml_cpp_repo_path="$(mlCppRepoPath)"
+
+    if [[ -n "$ml_cpp_repo_path" && ! -d "$ml_cpp_repo_path" ]]; then
+        printf -- 'Required ml-cpp Ivy repository not found at %s.\n' "$ml_cpp_repo_path" |& tee -a "$LOG_FILE"
+        printf -- 'The ml-cpp build did not create the expected Ivy repository.\n' |& tee -a "$LOG_FILE"
+        exit 1
+    fi
+
+    if [[ -n "$ml_cpp_repo_path" ]]; then
+        ml_cpp_artifact_dir="$(mlCppArtifactDir "$ml_cpp_repo_path")"
+        if hasMlCppIvyArtifacts "$ml_cpp_repo_path"; then
+            return 0
+        fi
+        for artifact in "$ml_cpp_artifact_dir/ml-cpp-${PACKAGE_VERSION}-SNAPSHOT-deps.zip" "$ml_cpp_artifact_dir/ml-cpp-${PACKAGE_VERSION}-SNAPSHOT-nodeps.zip"; do
+            [[ -f "$artifact" ]] || missing_artifacts+=("$artifact")
+        done
+
+        if (( ${#missing_artifacts[@]} > 0 )); then
+            printf -- 'Required s390x ml-cpp artifacts are missing:\n' |& tee -a "$LOG_FILE"
+            printf -- '  %s\n' "${missing_artifacts[@]}" |& tee -a "$LOG_FILE"
+            printf -- 'The ml-cpp build did not create the expected deps/nodeps artifacts.\n' |& tee -a "$LOG_FILE"
+            exit 1
+        fi
+    fi
+}
+
+function configureMlCppRepo() {
+    local ml_cpp_repo_url
+
+    verifyMlCppRepo
+    ml_cpp_repo_url="$(mlCppRepoUrl)"
+    ML_CPP_GRADLE_OPTS="-Dbuild.ml_cpp.repo=$ml_cpp_repo_url"
+    export ML_CPP_REPO ML_CPP_GRADLE_OPTS
+    grep -q "ML_CPP_REPO" "$BUILD_ENV" || printf -- "export ML_CPP_REPO=%q\n" "$ML_CPP_REPO" >> "$BUILD_ENV"
+    grep -q "ML_CPP_GRADLE_OPTS" "$BUILD_ENV" || printf -- "export ML_CPP_GRADLE_OPTS=%q\n" "$ML_CPP_GRADLE_OPTS" >> "$BUILD_ENV"
+    printf -- "Using ml-cpp Ivy repository: %s\n" "$ml_cpp_repo_url" |& tee -a "$LOG_FILE"
+}
+
+function resolveMlCppPytorchRoot() {
+    local root="$1"
+    local include_dir="$root/include"
+
+    if [[ -d "$root/include/pytorch/torch" || -d "$root/include/pytorch/c10" ]]; then
+        include_dir="$root/include/pytorch"
+    fi
+
+    if [[ -d "$include_dir" && -f "$root/lib/libtorch_cpu.so" && -f "$root/lib/libc10.so" ]]; then
+        ML_PYTORCH_HOME="$include_dir"
+        ML_PYTORCH_LIB_DIR="$root/lib"
+        return 0
+    fi
+    return 1
+}
+
+function resolveMlCppPytorchSourceBuild() {
+    local root="$1"
+    local lib_dir="$root/build/lib"
+
+    if [[ -d "$root/torch/csrc/api/include" && -f "$lib_dir/libtorch_cpu.so" && -f "$lib_dir/libc10.so" ]]; then
+        ML_PYTORCH_HOME="$root"
+        ML_PYTORCH_LIB_DIR="$lib_dir"
+        return 0
+    fi
+    return 1
+}
+
+function validateMlCppPytorch() {
+    if [[ -z "$ML_PYTORCH_HOME" || -z "$ML_PYTORCH_LIB_DIR" ]]; then
+        printf -- 'ML_PYTORCH_HOME and ML_PYTORCH_LIB_DIR must both be set for the s390x ml-cpp build.\n' |& tee -a "$LOG_FILE"
+        [[ -n "${ML_PYTORCH_SEARCH_PATHS:-}" ]] && printf -- 'Searched for a GCC13 PyTorch root in:\n%s\n' "$ML_PYTORCH_SEARCH_PATHS" |& tee -a "$LOG_FILE"
+        printf -- 'Provide ML_PYTORCH_ROOT, or mount/copy the GCC13 PyTorch bundle to one of the searched locations.\n' |& tee -a "$LOG_FILE"
+        exit 1
+    fi
+    [[ -d "$ML_PYTORCH_HOME" ]] || { printf -- 'ML_PYTORCH_HOME does not exist: %s\n' "$ML_PYTORCH_HOME" |& tee -a "$LOG_FILE"; exit 1; }
+    [[ -f "$ML_PYTORCH_LIB_DIR/libtorch_cpu.so" && -f "$ML_PYTORCH_LIB_DIR/libc10.so" ]] || { printf -- 'ML_PYTORCH_LIB_DIR must contain libtorch_cpu.so and libc10.so: %s\n' "$ML_PYTORCH_LIB_DIR" |& tee -a "$LOG_FILE"; exit 1; }
+
+    if command -v readelf >/dev/null 2>&1; then
+        local torch_comment
+        torch_comment="$(readelf -p .comment "$ML_PYTORCH_LIB_DIR/libtorch_cpu.so" 2>/dev/null || true)"
+        if [[ "$torch_comment" == *"GCC:"* && ! "$torch_comment" =~ GCC:.*13\. ]]; then
+            printf -- 'Warning: libtorch_cpu.so was not built with GCC 13; continuing with the available toolchain.\n' |& tee -a "$LOG_FILE"
+        fi
+    fi
+}
+
+function isSelectedCompilerPytorchLib() {
+    local libtorch_cpu="$1"
+    local torch_comment
+    local selected_major
+
+    if [[ ! -f "$libtorch_cpu" ]]; then
+        return 1
+    fi
+
+    if ! command -v readelf >/dev/null 2>&1; then
+        return 0
+    fi
+
+    torch_comment="$(readelf -p .comment "$libtorch_cpu" 2>/dev/null || true)"
+    if [[ "$torch_comment" != *"GCC:"* ]]; then
+        return 0
+    fi
+
+    selected_major="$("$CXX" -dumpfullversion -dumpversion 2>/dev/null | cut -d. -f1 || true)"
+    [[ -n "$selected_major" && "$torch_comment" =~ GCC:.*${selected_major}\. ]]
+}
+
+function configureGcc13Toolchain() {
+    local version gcc_bin gxx_bin default_gcc_major
+
+    ML_PYTORCH_GCC13_AVAILABLE="false"
+    if [[ -f /opt/rh/gcc-toolset-13/enable ]]; then
+        # shellcheck disable=SC1091
+        source /opt/rh/gcc-toolset-13/enable
+    fi
+
+    if [[ -x /opt/rh/gcc-toolset-13/root/usr/bin/gcc && -x /opt/rh/gcc-toolset-13/root/usr/bin/g++ ]]; then
+        CC="/opt/rh/gcc-toolset-13/root/usr/bin/gcc"; CXX="/opt/rh/gcc-toolset-13/root/usr/bin/g++"
+        export CC CXX ML_PYTORCH_GCC13_AVAILABLE="true" CMAKE_C_COMPILER="$CC" CMAKE_CXX_COMPILER="$CXX"
+        printf -- 'Using GCC 13 toolchain for PyTorch: CC=%s CXX=%s\n' "$CC" "$CXX" |& tee -a "$LOG_FILE"
+        return
+    fi
+
+    for version in 15 14 13 12 11 10 9; do
+        for gcc_bin in "gcc-$version" "gcc$version"; do
+            [[ "$gcc_bin" == gcc-* ]] && gxx_bin="g++-${version}" || gxx_bin="g++${version}"
+            if command -v "$gcc_bin" >/dev/null 2>&1 && command -v "$gxx_bin" >/dev/null 2>&1; then
+                CC="$(command -v "$gcc_bin")"; CXX="$(command -v "$gxx_bin")"
+                export CC CXX ML_PYTORCH_GCC13_AVAILABLE="true" CMAKE_C_COMPILER="$CC" CMAKE_CXX_COMPILER="$CXX"
+                printf -- 'Using GCC %s toolchain for PyTorch: CC=%s CXX=%s\n' "$version" "$CC" "$CXX" |& tee -a "$LOG_FILE"
+                return
+            fi
+        done
+    done
+
+    if command -v gcc >/dev/null 2>&1 && command -v g++ >/dev/null 2>&1; then
+        default_gcc_major="$(gcc -dumpfullversion -dumpversion 2>/dev/null | cut -d. -f1)"
+        if [[ "$default_gcc_major" =~ ^[0-9]+$ && "$default_gcc_major" -ge 9 ]]; then
+            CC="$(command -v gcc)"; CXX="$(command -v g++)"
+            export CC CXX ML_PYTORCH_GCC13_AVAILABLE="true" CMAKE_C_COMPILER="$CC" CMAKE_CXX_COMPILER="$CXX"
+            printf -- 'Using default GCC %s toolchain for PyTorch: CC=%s CXX=%s\n' "$default_gcc_major" "$CC" "$CXX" |& tee -a "$LOG_FILE"
+            return
+        fi
+    fi
+
+    CC="${CC:-gcc}"; CXX="${CXX:-g++}"
+    export CC CXX CMAKE_C_COMPILER="$CC" CMAKE_CXX_COMPILER="$CXX"
+    printf -- 'Warning: GCC >= 9 was not found; building PyTorch with CC=%s CXX=%s.\n' "$CC" "$CXX" |& tee -a "$LOG_FILE"
+    printf -- 'Using selected toolchain for PyTorch: CC=%s CXX=%s\n' "$CC" "$CXX" |& tee -a "$LOG_FILE"
+}
+
+function configureGitForLargePytorchClone() {
+    git config --global http.version HTTP/1.1 || true
+    git config --global http.postBuffer 524288000 || true
+    git config --global core.compression 0 || true
+    git config --global submodule.fetchJobs "$ML_PYTORCH_SUBMODULE_JOBS" || true
+}
+
+function buildMlCppPytorch() {
+    [[ "$ML_PYTORCH_BUILD_FROM_SOURCE" == "true" ]] || return
+
+    configureGcc13Toolchain
+    ensureBuildPythonUsable
+    configureGitForLargePytorchClone
+
+    if [[ -d "$ML_PYTORCH_SOURCE_DIR" && ! -f "$ML_PYTORCH_SOURCE_DIR/torch/abi-check.cpp" ]]; then
+        printf -- 'Removing incomplete PyTorch source at %s; missing torch/abi-check.cpp.\n' "$ML_PYTORCH_SOURCE_DIR" |& tee -a "$LOG_FILE"
+        rm -rf "$ML_PYTORCH_SOURCE_DIR"
+    fi
+
+    if resolveMlCppPytorchSourceBuild "$ML_PYTORCH_SOURCE_DIR"; then
+        if isSelectedCompilerPytorchLib "$ML_PYTORCH_LIB_DIR/libtorch_cpu.so"; then
+            printf -- 'Using existing PyTorch source build: source=%s lib=%s\n' "$ML_PYTORCH_HOME" "$ML_PYTORCH_LIB_DIR" |& tee -a "$LOG_FILE"
+            return
+        fi
+        if [[ "$ML_PYTORCH_GCC13_AVAILABLE" != "true" ]]; then
+            printf -- 'Using existing PyTorch build because no preferred compiler was found.\n' |& tee -a "$LOG_FILE"
+            return
+        fi
+        printf -- 'Existing PyTorch source build was not built with the selected compiler; rebuilding it.\n' |& tee -a "$LOG_FILE"
+        rm -rf "$ML_PYTORCH_SOURCE_DIR/build"
+        ML_PYTORCH_HOME=""
+        ML_PYTORCH_LIB_DIR=""
+    fi
+
+    printf -- 'Building PyTorch %s from source for s390x ml-cpp.\n' "$ML_PYTORCH_REF" |& tee -a "$LOG_FILE"
+    if [[ ! -d "$ML_PYTORCH_SOURCE_DIR/.git" ]]; then
+        local clone_attempt
+        for clone_attempt in 1 2 3 4 5; do
+            rm -rf "$ML_PYTORCH_SOURCE_DIR"
+            if git clone --depth 1 --branch "$ML_PYTORCH_REF" "$ML_PYTORCH_REPO_URL" "$ML_PYTORCH_SOURCE_DIR"; then
+                break
+            fi
+            if [[ "$clone_attempt" == "5" ]]; then
+                return 1
+            fi
+            printf -- 'PyTorch clone failed on attempt %s; retrying with a clean source directory.\n' "$clone_attempt" |& tee -a "$LOG_FILE"
+            sleep $((clone_attempt * 15))
+        done
+    else
+        printf -- 'Using existing PyTorch source at %s\n' "$ML_PYTORCH_SOURCE_DIR" |& tee -a "$LOG_FILE"
+    fi
+
+    cd "$ML_PYTORCH_SOURCE_DIR"
+    git submodule sync --recursive
+    local submodule_attempt required_submodule_file incomplete_submodule
+    for submodule_attempt in 1 2 3 4 5; do
+        if git submodule update --init --recursive --jobs "${ML_PYTORCH_SUBMODULE_JOBS}"; then
+            incomplete_submodule=0
+            for required_submodule_file in third_party/FP16/CMakeLists.txt third_party/FXdiv/CMakeLists.txt third_party/psimd/CMakeLists.txt; do
+                if [[ ! -f "$required_submodule_file" ]]; then
+                    printf -- 'PyTorch submodule update left %s missing; removing %s before retry.\n' "$required_submodule_file" "${required_submodule_file%/*}" |& tee -a "$LOG_FILE"
+                    rm -rf "${required_submodule_file%/*}"
+                    incomplete_submodule=1
+                fi
+            done
+            if [[ "$incomplete_submodule" == "0" ]]; then
+                break
+            fi
+        fi
+        if [[ "$submodule_attempt" == "5" ]]; then
+            return 1
+        fi
+        printf -- 'PyTorch submodule update failed on attempt %s; retrying.\n' "$submodule_attempt" |& tee -a "$LOG_FILE"
+        cd "$SOURCE_ROOT"
+        rm -rf "$ML_PYTORCH_SOURCE_DIR"
+        git clone --depth 1 --branch "$ML_PYTORCH_REF" "$ML_PYTORCH_REPO_URL" "$ML_PYTORCH_SOURCE_DIR" || return 1
+        cd "$ML_PYTORCH_SOURCE_DIR"
+        git submodule sync --recursive || true
+        sleep $((submodule_attempt * 15))
+    done
+
+    if ! runBuildPython -m pip --version >/dev/null 2>&1; then
+        local python_version get_pip_url
+        python_version="$(runBuildPython -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')"
+        get_pip_url="https://bootstrap.pypa.io/get-pip.py"
+        if [[ "$python_version" == "3.9" ]]; then
+            get_pip_url="https://bootstrap.pypa.io/pip/3.9/get-pip.py"
+        elif [[ "$python_version" == "3.8" ]]; then
+            get_pip_url="https://bootstrap.pypa.io/pip/3.8/get-pip.py"
+        fi
+        curl -SL -o get-pip.py "$get_pip_url"
+        runBuildPython get-pip.py --user
+    fi
+
+    local pip_user_opts=(--user)
+    runBuildPython -m pip install --help | grep -q -- '--break-system-packages' && pip_user_opts+=(--break-system-packages)
+
+    cd "$ML_PYTORCH_SOURCE_DIR"
+    runBuildPython -m pip install "${pip_user_opts[@]}" --upgrade pip setuptools wheel cython 'scikit-build<0.18'
+    runBuildPython -m pip install "${pip_user_opts[@]}" -r requirements.txt
+    runBuildPython -m pip install "${pip_user_opts[@]}" pyyaml typing_extensions numpy ninja cmake cffi sympy networkx jinja2 fsspec filelock cython
+
+    export PATH="$HOME/.local/bin:$PATH"
+    export MAX_JOBS="$ML_PYTORCH_BUILD_PARALLEL_LEVEL"
+    export BUILD_SHARED_LIBS=ON
+    for disabled in BUILD_TEST BUILD_PYTHON BUILD_CAFFE2_OPS USE_CUDA USE_ROCM USE_DISTRIBUTED USE_MPI USE_NCCL USE_GLOO USE_MKLDNN USE_FBGEMM USE_NNPACK USE_QNNPACK USE_XNNPACK USE_KINETO USE_MPS; do
+        export "$disabled=0"
+    done
+
+    if [[ -f "$ML_PYTORCH_SOURCE_DIR/build/CMakeCache.txt" ]]; then
+        printf -- 'Removing stale PyTorch CMake build directory before rebuilding libtorch.\n' |& tee -a "$LOG_FILE"
+        rm -rf "$ML_PYTORCH_SOURCE_DIR/build"
+    fi
+
+    cd "$ML_PYTORCH_SOURCE_DIR"
+    runBuildPython "$ML_PYTORCH_SOURCE_DIR/tools/build_libtorch.py" |& tee -a "$LOG_FILE"
+
+    resolveMlCppPytorchSourceBuild "$ML_PYTORCH_SOURCE_DIR" || { printf -- 'PyTorch build did not create required libtorch artifacts under %s/build/lib.\n' "$ML_PYTORCH_SOURCE_DIR" |& tee -a "$LOG_FILE"; exit 1; }
+}
+
+function configureMlCppPytorch() {
+    local candidate candidates
+
+    if [[ -n "$ML_PYTORCH_ROOT" ]]; then
+        if ! resolveMlCppPytorchRoot "$ML_PYTORCH_ROOT"; then
+            printf -- 'ML_PYTORCH_ROOT must contain include/, lib/libtorch_cpu.so and lib/libc10.so: %s\n' "$ML_PYTORCH_ROOT" |& tee -a "$LOG_FILE"
+            exit 1
+        fi
+    elif [[ -z "$ML_PYTORCH_HOME" && -z "$ML_PYTORCH_LIB_DIR" ]]; then
+        candidates=("$ML_CPP_SOURCE_DIR/deps/pytorch-gcc13" "$SOURCE_ROOT/deps/pytorch-gcc13" "$SOURCE_ROOT/pytorch-gcc13" "/usr/local/gcc133" "/opt/pytorch-gcc13" "/usr/local/pytorch-gcc13")
+        ML_PYTORCH_SEARCH_PATHS="$(printf -- '  %s\n' "${candidates[@]}")"
+        for candidate in "${candidates[@]}"; do
+            resolveMlCppPytorchRoot "$candidate" && break
+        done
+    fi
+
+    [[ -n "$ML_PYTORCH_HOME" && -n "$ML_PYTORCH_LIB_DIR" ]] || buildMlCppPytorch
+
+    validateMlCppPytorch
+    export ML_PYTORCH_HOME ML_PYTORCH_LIB_DIR
+    grep -q "ML_PYTORCH_HOME" "$BUILD_ENV" || printf -- "export ML_PYTORCH_HOME=%q\n" "$ML_PYTORCH_HOME" >> "$BUILD_ENV"
+    grep -q "ML_PYTORCH_LIB_DIR" "$BUILD_ENV" || printf -- "export ML_PYTORCH_LIB_DIR=%q\n" "$ML_PYTORCH_LIB_DIR" >> "$BUILD_ENV"
+    printf -- "Using GCC13 PyTorch for ml-cpp: include=%s lib=%s\n" "$ML_PYTORCH_HOME" "$ML_PYTORCH_LIB_DIR" |& tee -a "$LOG_FILE"
+}
+
+function buildMlCpp() {
+    local ml_cpp_repo_path ml_cpp_artifact_dir ml_cpp_dist_dir ml_cpp_deps_zip ml_cpp_nodeps_zip ml_cpp_cmake_flags="${CMAKE_FLAGS:-}" boost_compiler_tag
+
+    ml_cpp_repo_path="$(mlCppRepoPath)"
+    if [[ -z "$ml_cpp_repo_path" ]]; then
+        printf -- 'Using remote ml-cpp Ivy repository: %s\n' "$(mlCppRepoUrl)" |& tee -a "$LOG_FILE"
+        configureMlCppRepo
+        return
+    fi
+
+    ml_cpp_artifact_dir="$(mlCppArtifactDir "$ml_cpp_repo_path")"
+    if [[ "$ML_CPP_FORCE_REBUILD" != "true" ]] && hasMlCppIvyArtifacts "$ml_cpp_repo_path"; then
+        printf -- 'Using existing s390x ml-cpp Ivy artifacts from %s\n' "$ml_cpp_artifact_dir" |& tee -a "$LOG_FILE"
+        patchMlCppS390xBoostDepsZip "$ml_cpp_artifact_dir/ml-cpp-${PACKAGE_VERSION}-SNAPSHOT-deps.zip"
+        configureMlCppRepo
+        return
+    fi
+
+    [[ -d "$ML_CPP_SOURCE_DIR" ]] || { printf -- 'ml-cpp source directory not found: %s\n' "$ML_CPP_SOURCE_DIR" |& tee -a "$LOG_FILE"; exit 1; }
+
+    installMlCppJava
+    installMlCppBoost
+    installMlCppSystemPrefixLinks
+    installMlCppBinutilsAliases
+    configureMlCppPytorch
+    configureGcc13Toolchain
+    cleanStaleMlCppBuildDir
+
+    cd "$ML_CPP_SOURCE_DIR"
+    ml_cpp_dist_dir="$ML_CPP_SOURCE_DIR/build/distributions"
+    ml_cpp_deps_zip="$ml_cpp_dist_dir/ml-cpp-${PACKAGE_VERSION}-SNAPSHOT-deps.zip"
+    ml_cpp_nodeps_zip="$ml_cpp_dist_dir/ml-cpp-${PACKAGE_VERSION}-SNAPSHOT-nodeps.zip"
+    if [[ -f "$ml_cpp_nodeps_zip" ]]; then
+        [[ -f "$ml_cpp_deps_zip" ]] || ensureMlCppDepsZip "$ml_cpp_deps_zip"
+        patchMlCppS390xBoostDepsZip "$ml_cpp_deps_zip"
+        mkdir -p "$ml_cpp_artifact_dir"
+        cp "$ml_cpp_deps_zip" "$ml_cpp_nodeps_zip" "$ml_cpp_artifact_dir/"
+        printf -- 'Using existing ml-cpp artifacts from %s\n' "$ml_cpp_dist_dir" |& tee -a "$LOG_FILE"
+        configureMlCppRepo
+        return
+    fi
+
+    printf -- 'Building s390x ml-cpp artifacts.\n' |& tee -a "$LOG_FILE"
+    export GRADLE_USER_HOME=$SOURCE_ROOT/.gradle
+    if [[ -n "${CMAKE_C_COMPILER:-}" && -n "${CMAKE_CXX_COMPILER:-}" ]]; then
+        export ML_GCC_COMPILER="$CMAKE_C_COMPILER" ML_GXX_COMPILER="$CMAKE_CXX_COMPILER"
+        ml_cpp_cmake_flags="${ml_cpp_cmake_flags} -DCMAKE_C_COMPILER=$CMAKE_C_COMPILER -DCMAKE_CXX_COMPILER=$CMAKE_CXX_COMPILER -DML_GCC_COMPILER=$CMAKE_C_COMPILER -DML_GXX_COMPILER=$CMAKE_CXX_COMPILER"
+    fi
+    if boost_compiler_tag="$(mlCppBoostCompilerTag)"; then
+        export ML_BOOST_COMPILER_VER="$boost_compiler_tag"
+        ml_cpp_cmake_flags="${ml_cpp_cmake_flags} -DBoost_COMPILER=$boost_compiler_tag"
+    fi
+    CPP_CROSS_COMPILE=s390x CMAKE_BUILD_PARALLEL_LEVEL="${ML_CPP_BUILD_PARALLEL_LEVEL:-4}" JAVA_HOME="$ML_CPP_JAVA_HOME" PATH="$ML_CPP_JAVA_HOME/bin:$PATH" CMAKE_FLAGS="$ml_cpp_cmake_flags" BOOST_ROOT="$ML_CPP_BOOST_ROOT" ML_PYTORCH_HOME="$ML_PYTORCH_HOME" ML_PYTORCH_LIB_DIR="$ML_PYTORCH_LIB_DIR" ./gradlew ${ML_CPP_GRADLE_TASKS} -Dbuild.snapshot=true |& tee -a "$LOG_FILE"
+
+    [[ -f "$ml_cpp_deps_zip" ]] || ensureMlCppDepsZip "$ml_cpp_deps_zip"
+    patchMlCppS390xBoostDepsZip "$ml_cpp_deps_zip"
+    mkdir -p "$ml_cpp_artifact_dir"
+    cp "$ml_cpp_deps_zip" "$ml_cpp_nodeps_zip" "$ml_cpp_artifact_dir/"
+
+    configureMlCppRepo
+}
+
+if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
+    buildMlCpp "$@"
+fi
