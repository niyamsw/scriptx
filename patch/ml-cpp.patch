+function installMlCppJava() {
+    if [[ -x "$ML_CPP_JAVA_HOME/bin/java" ]]; then
+        return
+    fi
+
+    printf -- "Download and install Java 17 for ml-cpp build \n"
+    cd "$SOURCE_ROOT"
+    sudo mkdir -p "$ML_CPP_JAVA_HOME"
+    curl -SL -o jdk17.tar.gz "$(getMlCppJavaUrl Temurin17 jdk)"
+    sudo tar -zxf jdk17.tar.gz -C "$ML_CPP_JAVA_HOME" --strip-components 1
+}
+
+function installMlCppBoost() {
+    local boost_args
+    local boost_iostreams
+    local zlib_lib
+    local zlib_libdir
+
+    if find "$ML_CPP_BOOST_ROOT" -path '*/BoostConfig.cmake' -print -quit 2>/dev/null | grep -q .; then
+        boost_iostreams="$(find "$ML_CPP_BOOST_ROOT/lib" -maxdepth 1 -type f -name 'libboost_iostreams*.so*' 2>/dev/null | head -1 || true)"
+        if [[ -n "$boost_iostreams" ]] && nm -D "$boost_iostreams" 2>/dev/null | c++filt | grep -q 'boost::iostreams::zlib::deflated'; then
+            printf -- 'Using existing Boost 1.86 installation at %s\n' "$ML_CPP_BOOST_ROOT" |& tee -a "$LOG_FILE"
+            return
+        fi
+        printf -- 'Existing Boost 1.86 installation lacks zlib iostreams support; rebuilding.\n' |& tee -a "$LOG_FILE"
+        sudo rm -rf "$ML_CPP_BOOST_ROOT/include/boost" "$ML_CPP_BOOST_ROOT/lib/libboost_"* "$ML_CPP_BOOST_ROOT/lib/cmake/Boost"* "$ML_CPP_BOOST_ROOT/lib/cmake/boost_"*
+        rm -rf "$ML_CPP_BOOST_SOURCE_DIR"
+    fi
+
+    printf -- 'Building Boost 1.86 for ml-cpp.\n' |& tee -a "$LOG_FILE"
+    cd "$SOURCE_ROOT"
+    if [[ ! -d "$ML_CPP_BOOST_SOURCE_DIR" ]]; then
+        curl -SL -o boost_1_86_0.tar.bz2 https://archives.boost.io/release/1.86.0/source/boost_1_86_0.tar.bz2
+        tar -xjf boost_1_86_0.tar.bz2
+    fi
+
+    cd "$ML_CPP_BOOST_SOURCE_DIR"
+    ./bootstrap.sh --without-libraries=context,coroutine,graph_parallel,mpi,python --without-icu |& tee -a "$LOG_FILE"
+    if ! grep -q '{3ul, 13ul' boost/unordered/detail/prime_fmod.hpp; then
+        patch -p0 < "$PATCH_DIR/boost-prime-fmod.patch" |& tee -a "$LOG_FILE"
+    fi
+    zlib_lib="$(find /usr/lib64 /usr/lib /lib64 /lib /usr/lib/s390x-linux-gnu /lib/s390x-linux-gnu -maxdepth 1 -name 'libz.so' 2>/dev/null | head -1 || true)"
+    zlib_libdir="$(dirname "${zlib_lib:-/usr/lib64/libz.so}")"
+    boost_args=(--with-iostreams --with-filesystem --with-program_options --with-regex --with-date_time --with-log --with-thread --with-test --layout=versioned --disable-icu pch=off optimization=speed inlining=full define=BOOST_MATH_NO_LONG_DOUBLE_MATH_FUNCTIONS define=BOOST_LOG_WITHOUT_DEBUG_OUTPUT define=BOOST_LOG_WITHOUT_EVENT_LOG define=BOOST_LOG_WITHOUT_SYSLOG define=BOOST_LOG_WITHOUT_IPC define=_FORTIFY_SOURCE=2 "-sZLIB_INCLUDE=/usr/include" "-sZLIB_LIBPATH=$zlib_libdir" "cxxflags=-std=gnu++17 -fstack-protector" "cflags=-D__STDC_FORMAT_MACROS" "linkflags=-std=gnu++17 -Wl,-z,relro -Wl,-z,now")
+    ./b2 -j"${ML_CPP_BUILD_PARALLEL_LEVEL:-4}" "${boost_args[@]}" |& tee -a "$LOG_FILE"
+    sudo ./b2 install --prefix="$ML_CPP_BOOST_ROOT" "${boost_args[@]}" |& tee -a "$LOG_FILE"
+}
